/**
 * Implements hook_node_view_alter().
 */
function custom_node_view_alter(&$build) {
  
  if($build['#node']->type == 'technology') {
    
    $node = $build['#node'];
    if (!empty($node->field_technology_desc) && $node->field_technology_desc[LANGUAGE_NONE][0]['nid']) {
      $desc_nid = $node->field_technology_desc[LANGUAGE_NONE][0]['nid'];
      $build['body']['#suffix'] = '<div class="node-readmore">'.l('Читать подробнее', 'node/'.$desc_nid/*, array('attributes' => array('class' => array('node-readmore')))*/).'</div>';
     
    }
  }
}

/**
 *
 */
function custom_devices_page($term = NULL) {
  $content_devices = $content_mats = $devices_list = $mats_list = $mat_title = '';
  $show_mats = $show_devices = TRUE;

  $breadcrumbs = array();
  $breadcrumbs[] = l(t('Home'), '<front>'); 
  $breadcrumbs[] = l('Оборудование и материалы', 'oborudovanie-i-materialy'); 
  
  //drupal_set_breadcrumb($breadcrumbs);
  
  if (!is_null($term) && $term->vid == 7) {    
    $devices_tree = taxonomy_get_tree(7, $term->tid, 1);  
    $show_mats = FALSE;    
    module_load_include('inc', 'taxonomy', 'taxonomy.pages');
    $build = _taxonomy_term_page($term);
    $devices_list = render($build);    
  } else {
    $devices_tree = taxonomy_get_tree(7, 0, 1);  
    if (!is_null($term) && $term->vid != 5) {
      array_pop($breadcrumbs);
      $breadcrumbs[] = 'Оборудование и материалы';
    } else {
      $mats_term = taxonomy_term_load(93);
      $devices_tree[] = $mats_term;
    }
  }
  //dsm($term);
  if (is_null($term)) {
    $mats_tree = taxonomy_get_tree(5, 93, 1);  
    $mat_title = '<h2>Расходные материалы</h2>';
  } elseif ($term->vid == 5) {    
    $mats_tree = taxonomy_get_tree(5, $term->tid, 1); 
    $show_devices = FALSE;
    module_load_include('inc', 'taxonomy', 'taxonomy.pages');
    //$build = array('header' => array('#markup' => '<h2>Расходные материалы - '.$term->name.'</h2>', '#weight' => -10));
    $build = _taxonomy_term_page($term);
    $mats_list = render($build);
  }

  if ($show_devices) {
    foreach($devices_tree as $t) {    
      $term_wrapper = entity_metadata_wrapper('taxonomy_term', $t->tid);

      $childs = taxonomy_get_tree($t->vid, $t->tid, 1);
      $sub_terms = array(); $sub_count = 0;
      foreach($childs as $child) { 
        $sub_count++;
        $sub_terms[] = l($child->name, 'taxonomy/term/'.$child->tid);
        if ($sub_count >= 3) {
          break;
        }
      }    
      
      $img = $term_wrapper->field_device_image->value();
      $content_devices .= '<div class="row">'.l(theme('image', array('path' => image_style_url('device_preview', $img['uri']))), 'taxonomy/term/'.$t->tid, array('html' => TRUE)). '<h2>'.l($term_wrapper->name->value(), 'taxonomy/term/'.$t->tid).'</h2>
                '.theme('item_list', array('items' => $sub_terms)).' <div class="more">'.l('Подробнее', 'taxonomy/term/'.$t->tid).'</div></div>';

    }
    if ($content_devices) {
      $content_devices = '<div class="devices-wrapper">'.$content_devices.'</div>';
    }
  }  

  if ($show_mats) {
    foreach($mats_tree as $t) {
      $term_wrapper = entity_metadata_wrapper('taxonomy_term', $t->tid);

      $childs = taxonomy_get_tree(5, $t->tid, 1);
      $sub_terms = array();    
      foreach($childs as $child) {
        $sub_terms[] = l($child->name, 'taxonomy/term/'.$child->tid);
      }    
      $sub_terms_content = "";
      if ($sub_terms) {
        $arr = array_chunk($sub_terms, round(count($sub_terms)/2));  
      }    
      if (!empty($arr) && count($arr) > 0) {
         $sub_terms_content .= '<div class="column">'.theme('item_list', array('items' => $arr[0])).'</div>';
      }
      if (!empty($arr) && count($arr) == 2) {
         $sub_terms_content .= '<div class="column">'.theme('item_list', array('items' => $arr[1])).'</div>';
      }
      $img = $term_wrapper->field_device_image->value();
      $content_mats .= '<div class="row"><div class="image-wrapper">'.theme('image', array('path' => image_style_url('preview_materials', $img['uri']))). '</div><div class="category-wrapper"><h2>'.$term_wrapper->name->value().'</h2>'.$sub_terms_content .'
       <div class="more">'.l('Ещё', 'taxonomy/term/'.$t->tid).'</div></div></div>';
    }
    if ($content_mats) {
      $content_mats = '<div class="mats-wrapper">'.$mat_title.$content_mats.'</div>';
    }
  }  

  if (!is_null($term)) {
    $breadcrumb = array();  
    // Build breadcrumb based on the hierarchy of the term.
    $current = (object) array(
      'tid' => $term->tid,
    );
    while ($parents = taxonomy_get_parents($current->tid)) { 
      $current = array_shift($parents);
      $breadcrumb[] = l($current->name, 'taxonomy/term/' . $current->tid);
    }
    //$breadcrumb = array_reverse($breadcrumb);
    $breadcrumbs = array_merge($breadcrumbs, array_reverse($breadcrumb)); 
    $breadcrumbs[] = $term->name;
  }  
  
  drupal_set_breadcrumb($breadcrumbs); 

  return $content_devices . $devices_list . $content_mats . $mats_list;
}

/**
 * Implements hook_menu_alter().
 */
function custom_menu_alter(&$items) {
  // Example - disable the page at node/add
  /*
   *$items['node/add']['access callback'] = FALSE;
   */
  /* Your code here */
  $items['taxonomy/term/%taxonomy_term']['page callback'] = 'custom_taxonomy_term_page';
}

/**
 *
 */
function custom_taxonomy_term_page($term) {  

  if ($term->vid != 5 && $term->vid != 7) {  

    module_load_include('inc','taxonomy', 'taxonomy.pages');
    return _taxonomy_term_page($term);  
  } else {
    return custom_devices_page($term);
  }
}

/**
 *
 */
function _taxonomy_term_page($term) {

  // If there is a menu link to this term, the link becomes the last part of
  // the active trail, and the link name becomes the page title. Thus, we must
  // explicitly set the page title to be the term title.
  drupal_set_title($term->name);

  // Build breadcrumb based on the hierarchy of the term.
  $current = (object) array(
    'tid' => $term->tid,
  );

  // @todo This overrides any other possible breadcrumb and is a pure hard-coded
  //   presumption. Make this behavior configurable per vocabulary or term.

  // Build breadcrumb based on the hierarchy of the term.
  $current = (object) array(
    'tid' => $term->tid,
  );

  // @todo This overrides any other possible breadcrumb and is a pure hard-coded
  //   presumption. Make this behavior configurable per vocabulary or term.
  $breadcrumb = array();
  while ($parents = taxonomy_get_parents($current->tid)) {
    $current = array_shift($parents);
    $breadcrumb[] = l($current->name, 'taxonomy/term/' . $current->tid);
  }
  $breadcrumb[] = l(t('Home'), NULL);
  $breadcrumb = array_reverse($breadcrumb); //dsm($breadcrumb);
  drupal_set_breadcrumb($breadcrumb);
  
  //drupal_add_feed('taxonomy/term/' . $term->tid . '/feed', 'RSS - ' . $term->name);

  // Set the term path as the canonical URL to prevent duplicate content.
  $uri = entity_uri('taxonomy_term', $term);
  drupal_add_html_head_link(array(
    'rel' => 'canonical',
    'href' => url($uri['path'], $uri['options']),
  ), TRUE);

  // Set the non-aliased path as a default shortlink.
  drupal_add_html_head_link(array(
    'rel' => 'shortlink',
    'href' => url($uri['path'], array_merge($uri['options'], array(
      'alias' => TRUE,
    ))),
  ), TRUE);

  // Normally we would call taxonomy_term_show() here, but for backwards
  // compatibility in Drupal 7 we do not want to do that (it produces different
  // data structures and HTML markup than what Drupal 7 released with). Calling
  // taxonomy_term_view() directly provides essentially the same thing, but
  // allows us to wrap the rendered term in our desired array structure.
  $build['term_heading'] = array(
    '#prefix' => '<div class="term-listing-heading">',
    '#suffix' => '</div>',
    'term' => taxonomy_term_view($term, 'full'),
  );

  $tids = array();
  custom_taxonomy_get_children($term->tid, $tids);
  /*$tids = taxonomy_get_children($term->tid);
  $tids = array_keys($tids);
  $tids[] = (int)$term->tid;
  */
  
  $query = db_select('taxonomy_index', 'i')->extend('PagerDefault');  
  $query->leftJoin('node', 'n', ' n.nid = i.nid AND n.status = 1 ');
  $query->fields('i', array('nid'))->condition('i.tid', $tids, 'IN'); 
  $query->groupBy('i.nid');
  $query->orderBy('n.created', 'DESC');
  $query->limit(20)->addTag('node_access'); //dsm($query->__toString());

  $nids = $query->execute()->fetchCol(); //dsm($nids);
  if ($nids) {
    $nodes = node_load_multiple($nids);
    $build += node_view_multiple($nodes);
    $build['pager'] = array(
      '#theme' => 'pager',
      '#weight' => 5,
    );
  }
 /* else {
    $build['no_content'] = array(
      '#prefix' => '<p>',
      '#markup' => t('There is currently no content classified with this term.'),
      '#suffix' => '</p>',
    );
  }*/
  return $build;
}

/**
 *
 */
function custom_taxonomy_get_children($tid, &$tids) {
	$child_tids = taxonomy_get_children($tid);      
	$child_tids = array_keys($child_tids);
	$child_tids[] = (int)$tid;
	foreach($child_tids as $child_tid) {
		if ($child_tid && !in_array($child_tid, $tids)) {
			$tids[] = $child_tid;
			custom_taxonomy_get_children($child_tid, $tids);
		}		
	}	
	return;
}


/**
 *
 */
function custom_technology_page($node) {
  drupal_set_title($node->title);
  $content = '';

  // $breadcrumbs = array();
  // $breadcrumbs[] = l(t('Home'), '<front>'); 
  // $breadcrumbs[] = l('Промышленный клининг', 'node/106'); 
  // $breadcrumbs[] = $node->title; 
  // drupal_set_breadcrumb($breadcrumbs);
  
  $view = node_view($node, 'teaser');
  if (!empty($node->field_technology_desc) && $node->field_technology_desc[LANGUAGE_NONE][0]['nid']) {
    $desc_nid = $node->field_technology_desc[LANGUAGE_NONE][0]['nid'];
    $view['links']['node']['#links']['node-readmore']['href'] = 'node/'.$desc_nid;
  }
  $content .= render($view);

  return  $content;
}

