/**
 * Implements hook_block_view().
 */
function custom_block_view($delta = '', $p = 0) {
  $block = array();

  switch ($delta) {

    case 'custom_prod_for_technolnogy':

      if (count(arg()) == 2 && arg(0) == 'node') {
        $nid = arg(1);
        $node = node_load($nid);
        if ($node->type == 'technology') {
          $block['subject'] = t('Продукция');    

          $query = db_select('field_data_field_technology', 'ft')->condition('ft.bundle', "product")->condition('field_technology_nid', $node->nid)->distinct();
          $query->leftJoin('taxonomy_index', 'i', ' i.nid = ft.entity_id');
          $query->leftJoin('taxonomy_term_data', 't', ' i.tid = t.tid');
          $query->condition('t.vid', 5);
          $query->addField('t','tid', 'tid');          
          $tids = $query->execute()->fetchCol();

          $mats_tree = taxonomy_get_tree(5, 93);
          $needed_cats = array();
          foreach($mats_tree as $t) {
            if (in_array($t->tid, $tids)) {
              // та категория
              if ($t->parents[0] != 93 && !in_array($t->parents[0], array_keys($needed_cats))) {
                $needed_cats[$t->parents[0]] = taxonomy_term_load($t->parents[0]);
              }
            }
          }
          
          if ($needed_cats) {
            $content_mats = '';
            foreach($needed_cats as $t) {
              $term_wrapper = entity_metadata_wrapper('taxonomy_term', $t->tid);

              $childs = taxonomy_get_tree(5, $t->tid, 1);
              $sub_terms = array();    
              foreach($childs as $child) {
                $sub_terms[] = l($child->name, 'taxonomy/term/'.$child->tid);
              }    
              $sub_terms_content = "";
              if ($sub_terms) {
                $arr = array_chunk($sub_terms, round(count($sub_terms)/2));  
              }    
              if (!empty($arr) && count($arr) > 0) {
                 $sub_terms_content .= '<div class="column">'.theme('item_list', array('items' => $arr[0])).'</div>';
              }
              if (!empty($arr) && count($arr) == 2) {
                 $sub_terms_content .= '<div class="column">'.theme('item_list', array('items' => $arr[1])).'</div>';
              }
              $img = $term_wrapper->field_device_image->value();
              $content_mats .= '<div class="row"><div class="image-wrapper">'.theme('image', array('path' => image_style_url('preview_materials', $img['uri']))). '</div><div class="category-wrapper"><h2>'.$term_wrapper->name->value().'</h2>'.$sub_terms_content .'
               <div class="more">'.l('Ещё', 'taxonomy/term/'.$t->tid).'</div></div></div>';
            }
            if ($content_mats) {
              $content_mats = '<div class="mats-wrapper">'.$content_mats.'</div>';
            }
            $block['content'] = $content_mats;
          }
          
        }
      }
      
      break;

    case 'custom_devices_for_technolnogy':

        if (count(arg()) == 2 && arg(0) == 'node') {
          $nid = arg(1);
          $nw = entity_metadata_wrapper('node', $nid);
          if ($nw->type->value() == 'technology') {
          	$block['subject'] = t('Оборудование');
          	if ($nw->field_title_for_devices_block->value()) {
          		$block['subject'] = $nw->field_title_for_devices_block->value();
          	}
            $query = db_select('field_data_field_technology', 'ft')->condition('ft.bundle', "device")->condition('field_technology_nid', $nw->nid->value())->distinct();
            $query->leftJoin('taxonomy_index', 'i', ' i.nid = ft.entity_id');
            $query->leftJoin('taxonomy_term_data', 't', ' i.tid = t.tid');
            $query->condition('t.vid', 7);
            $query->addField('t','tid', 'tid');          
            $tids = $query->execute()->fetchCol();

            $device_tree = taxonomy_get_tree(7, 0);
            $needed_cats = array();
            foreach($device_tree as $t) {
              if (in_array($t->tid, $tids)) {
                // та категория
                if ($t->parents[0] && !in_array($t->parents[0], $needed_cats)) {
                  $needed_cats[] = $t->parents[0];
                }
              }
            }
            
            $content_devices = '';
            
            /*if (count($needed_cats)>1) {
              foreach($needed_cats as $tid) {  
              	if (!empty($tid) && is_numeric($tid)) {
              		$term_wrapper = entity_metadata_wrapper('taxonomy_term', $tid);

	                $childs = taxonomy_get_tree($term_wrapper->value()->vid, $tid, 1);
	                $sub_terms = array(); $sub_count = 0;
	                foreach($childs as $child) { 
	                  $sub_count++;
	                  $sub_terms[] = l($child->name, 'taxonomy/term/'.$child->tid);
	                  if ($sub_count >= 3) {
	                    break;
	                  }
	                }    
	                
	                $img = $term_wrapper->field_device_image->value();
	                $content_devices .= '<div class="row">'.l(theme('image', array('path' => image_style_url('device_preview', $img['uri']))), 'taxonomy/term/'.$tid, array('html' => TRUE)). '<h2>'.l($term_wrapper->name->value(), 'taxonomy/term/'.$tid).'</h2>
	                '.theme('item_list', array('items' => $sub_terms)).' <div class="more">'.l('Подробнее', 'taxonomy/term/'.$tid).'</div></div>';
              	}
              }
              if ($content_devices) {
                $content_devices = '<div class="devices-wrapper">'.$content_devices.'</div>';
              }
              $block['content'] = $content_devices;
            } else*/if(count($needed_cats)>0) {

              $limit = 10;

              $devices = db_select('field_data_field_technology', 't')->fields('t', array('entity_id'))
                          ->extend('PagerDefault')->condition('t.bundle', 'device')
                          ->condition('t.field_technology_nid', $nid)->limit($limit)
                          ->execute()->fetchCol();
              //dsm($devices);
              $tids = array();
              custom_taxonomy_get_children($needed_cats[0], $tids);

              $build = array();
              if ($devices) {
                $nodes = node_load_multiple($devices);
                $build += node_view_multiple($nodes);
                $build['pager'] = array(
                  '#theme' => 'ajax_pager',
                  '#weight' => 5,
                  '#parameters' => array('selector' => "block-custom-custom-devices-for-technolnogy", 'callback' => 'custom_devices_for_technolnogy')
                );
                $block['content'] = render($build);
              }
            }
          }
        }
      break;

    case 'custom_info_for_technolnogy':
        if (count(arg()) == 2 && arg(0) == 'node') {
          $nid = arg(1);
          $nw = entity_metadata_wrapper('node', $nid);
          if ($nw->type->value() == 'technology') {
            $block['subject'] = t('Дополнительная информация');
            if ($nw->field_title_for_technology_info->value()) {
              $block['subject'] = $nw->field_title_for_technology_info->value();
            }
            if ($nw->field_technology_dop_info->value()) {
              $info = $nw->field_technology_dop_info->value();
              $block['content'] = '';
              $labels = array();
              $content = array();
              foreach($info as $key => $col) { 
                $labels[] = '<span infoblock="'.$key.'">'.$nw->field_technology_dop_info[$key]->field_technology_dop_tab_title->value().'</span>';
                $content[] = '<div class="info-data info-data-'.$key.'">'.$nw->field_technology_dop_info[$key]->field_technology_dop_tab_data->value()['value'].'</div>';
              }
              if ($labels && $content) {
                $block['content'] .= '<div class="info-block"><div class="info-tabs">'.implode('', $labels).'</div>'.
                implode('', $content).'</div>';
              }
            }
          }
        }
        break;

    case 'custom_menu_for_technolnogy':
        $block['subject'] = 'В каких сферах применим';

        $nid = arg(1);
        $node = node_load($nid);
        if ($node->type == 'technology' /*|| arg(0) == 'technology'*/) {
          $query = db_select('field_data_field_technology', 'ft')->condition('ft.bundle', 'use')->condition('field_technology_nid', $node->nid);
          $query->leftJoin('field_data_field_link_material', 'fm', " fm.bundle = 'use' AND fm.entity_id = ft.entity_id");
          $query->addField('fm','field_link_material_nid', 'nid');
          $query->groupBy('fm.field_link_material_nid');
          $nids = $query->execute()->fetchCol();          
          $paths = array();
          foreach ($nids as $nid) {
            $paths[] = 'node/'.$nid;
          }
          
          $mt = menu_tree('menu-application');
          foreach($mt as $mid => $m) {
            if (is_numeric($mid) && !in_array($m['#href'], $paths)) {
              unset($mt[$mid]);
            }
          }
          $block['content'] = $mt;
        }

      break;
    
    case 'custom_technology_video':

        $args = arg();
        if ($args[0] == 'node' && is_numeric($args[1])) {
          $node = node_load($args[1]);
          if ($node->type == 'technology') {
            $node_view = node_view($node); //dsm($node_view['field_technology_video']);
            // $node_view['field_technology_video']['#items'][0]['title'] = $node->title;
            $node_view['field_technology_video'][0]['file']['#options']['attributes']['title'] = $node->title;
            $block['content'] = render($node_view['field_technology_video']);
          }
        }
      break;

    case 'custom_mats_devices_for_front':

        $block['title'] = "Оборудование и материалы Best in sales";

        $items = array();

        $device_tree = taxonomy_get_tree(7, 0, 1);
        $mats_tree = taxonomy_get_tree(5, 0, 1);
        $device_tree = array_merge($device_tree, $mats_tree);
        $limit = 4; $i = 1;
        foreach($device_tree as $t) {
          $tw = entity_metadata_wrapper('taxonomy_term', $t->tid);
          $img = $tw->field_device_image->value();
          
          $items[] = l(theme('image_style', array('style_name' => 'dev_and_mats_front', 'path' => $img['uri'])), 'taxonomy/term/'.$t->tid, array('html' => TRUE)).
          '<h3>'.l($t->name, 'taxonomy/term/'.$t->tid, array('html' => TRUE)).'</h3>';
          $i++;
          if ($i > $limit)
          	break;
        }

        
        // $twm = entity_metadata_wrapper('taxonomy_term', $mats_tree[0]->tid);
        // dsm($twm->value());

        if ($items) {
          $block['content'] = theme('item_list', array('items' => $items));
        }

      break;

    case 'custom_mats_devices_root':

      $block['content'] = custom_devices_page();

      break;

    case 'custom_recomended_devices':

      $nid = arg(1);
      $output = '';
      if (arg(0) == 'node' && is_numeric($nid)) {
        $nw = entity_metadata_wrapper('node', $nid);
        if ($nw->type->value() == 'device') {
          if ($nw->field_recomened_devices->value()) {
            
            foreach($nw->field_recomened_devices->value() as $rec_node) {
              if (is_null($rec_node)) {
                continue;
              }
              $node_view = node_view($rec_node, 'teaser');
              $output .= drupal_render($node_view);
            }
          } else {
            $vb = module_invoke('views', 'block_view', 'product_recommend-block_1');
            $output = $vb['content'];
          }
        }
      }
      $block['title'] = 'Рекомендуем к товару';
      $block['content'] = $output;

      break;

    case 'custom_recomended_products':

      $nid = arg(1);
      $output = '';
      if (arg(0) == 'node' && is_numeric($nid)) {
        $nw = entity_metadata_wrapper('node', $nid);
        if ($nw->type->value() == 'product') {
          if ($nw->field_recomened_products->value()) {
            $even = 1;
            foreach($nw->field_recomened_products->value() as $rec_node) { 
              if (is_null($rec_node)) {
                continue;
              }
              $node_view = node_view($rec_node, 'teaser');
              if ($even % 2 == 0) {
                $output .= '<div class="views-row views-row-even">'.drupal_render($node_view).'</div>';
              } else {
                $output .= '<div class="views-row views-row-odd">'.drupal_render($node_view).'</div>';
              }
              $even++;
            }
          } else {
            $vb = module_invoke('views', 'block_view', 'product_recommend-block');
            $output = $vb['content'];
          }
        }
      }

      $block['title'] = 'Рекомендуем к товару';
      $block['content'] = $output; 

      break;

    case 'custom_search_block':

      $block['header'] = t('Search');
      $block['content'] = drupal_get_form('custom_search_form');

      break;
  }
  return $block;
}

/**
 * Implements hook_block_view_alter().
 */
function custom_block_view_alter(&$data, $block) { 
  $args = arg(); 
  
  if ($block->module == 'views' && $block->delta == 'use-block_1' && $args[0] == 'node' && is_numeric($args[1])) {  	
  	$nw = entity_metadata_wrapper('node', $args[1]); 
  	if ($nw->type->value() == 'technology' && $nw->field_title_for_use_block->value()) {
  		$data['subject'] = $nw->field_title_for_use_block->value();
  	}
  }
}

/**
 *
 */
function custom_search_form($form, &$form_state) {

  $form['text'] = array(
    '#type' => 'textfield',
    '#default_value' => '',
    '#size' => 40,
    '#maxlength' => 255,
    '#required' => TRUE,
    '#attributes' => array(
      'placeholder' => 'Поиск'
     ),
    '#prefix' => '<div class="container-inline">',
  );

  $form['#attributes']['class'][] = 'hidden-form';
  $form['actions'] = array(
    '#type' => 'actions',
    '#suffix' => '</div>',
  );
  $form['actions']['submit'] = array(
    '#type' => 'submit',
    '#value' => t('Search'),
  );

  return $form;
}

/**
 *
 */
function custom_search_form_validate($form, &$form_state) {
  if (strlen($form_state['values']['text']) < 2) {
    form_set_error('text', 'Для поиска необходимо ввести хотя бы 2 буквы.');
  }
}

/**
 *
 */
function custom_search_form_submit($form, &$form_state) {
  if (!form_get_errors()) {
    drupal_goto('search', array('query' => array('search_phrase' => $form_state['values']['text'])));
  }
}

/**
 *
 */
function custom_devices_for_technolnogy($url = '', $p = 0) {

  $output = '';
  $args  = explode("/", $url);

  if (count($args) == 2 && $args[0] == 'node') {
    $nid = $args[1];
    $nw = entity_metadata_wrapper('node', $nid);

    if ($nw->type->value() == 'technology') {
      $block['subject'] = t('Оборудование');
      if ($nw->field_title_for_devices_block->value()) {
        $block['subject'] = $nw->field_title_for_devices_block->value();
      }
      $query = db_select('field_data_field_technology', 'ft')->condition('ft.bundle', "device")->condition('field_technology_nid', $nw->nid->value())->distinct();
      $query->leftJoin('taxonomy_index', 'i', ' i.nid = ft.entity_id');
      $query->leftJoin('taxonomy_term_data', 't', ' i.tid = t.tid');
      $query->condition('t.vid', 7);
      $query->addField('t','tid', 'tid');          
      $tids = $query->execute()->fetchCol();

      $device_tree = taxonomy_get_tree(7, 0);
      $needed_cats = array();
      foreach($device_tree as $t) {
        if (in_array($t->tid, $tids)) {
          // та категория
          if ($t->parents[0] && !in_array($t->parents[0], $needed_cats)) {
            $needed_cats[] = $t->parents[0];
          }
        }
      }

      $content_devices = '';
      
     if(count($needed_cats)>0) {

        $limit = 10;

        $devices = db_select('field_data_field_technology', 't')->fields('t', array('entity_id'))
                    ->extend('PagerDefault')->condition('t.bundle', 'device')
                    ->condition('t.field_technology_nid', $nid)->limit($limit)
                    ->execute()->fetchCol();
        //dsm($devices);
        $tids = array();
        custom_taxonomy_get_children($needed_cats[0], $tids);

        $build = array();
        if ($devices) {
          $nodes = node_load_multiple($devices);
          $build += node_view_multiple($nodes);
          $build['pager'] = array(
            '#theme' => 'ajax_pager',
            '#weight' => 5,
            '#parameters' => array('selector' => "block-custom-custom-devices-for-technolnogy", 'callback' => 'custom_block_view')
          );
          $output = render($build);
        }
        if ($output != '') {
          $output = '<h2>Оборудование, системы очистки сухим льдом и снегом.</h2><div class="content">'.$output.'</div>';
        }
      }
    }
  }

  return $output;
}

/***************************************************************************
 * Color box styling
 */

/**
 * Implements hook_form_FORM_ID_alter().
 */
function custom_form_colorbox_admin_settings_alter(&$form, &$form_state) {
  $path = drupal_get_path('module', 'custom') . '/colorbox/styles/drsauber';
  
  // Убираем из селекта вариант "None". Потом мы его вернем в самый конец, чтобы
  // форма имела эстетический вид.
  unset($form['colorbox_custom_settings']['colorbox_style']['#options']['none']);

  // Добавляем в селект свой стиль.
  $form['colorbox_custom_settings']['colorbox_style']['#options'][$path] = t('Dr-sauber');

  // Возвращаем в селект вариант "None".
  $form['colorbox_custom_settings']['colorbox_style']['#options']['none'] = t('None');
}

/**
 * Implements hook_colorbox_settings_alter().
 */
function custom_colorbox_settings_alter(&$settings, &$style) {
  if ($style == drupal_get_path('module', 'custom') . '/colorbox/styles/drsauber') {
    drupal_add_js($style . '/colorbox_style.js');
    drupal_add_css($style . '/colorbox_style.css');
    
    // Мы можем альтернуть настройки колорбокса.
    $settings['fixed'] = FALSE;
    //$settings['reposition'] = FALSE;
  }
}