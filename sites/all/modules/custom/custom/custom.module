<?php

function custom_form_alter(&$form, &$form_state, $form_id){
  if($form['#id'] == 'webform-client-form-7--2' || $form['#id'] == 'webform-client-form-7'){
    $form['actions']['resetbutton'] = array(
      '#markup' => '<button class="cancel-button" type="reset" value="Отмена"/>',
      '#weight' => 1000
    );
  }
  if ($form_id == 'views_exposed_form' && $form['#id'] == 'views-exposed-form-use-block') {
    $by_technology = variable_get('custom_direction_by_technology', get_direction_by_technology());
    $direct_nid = arg(1);
    if (is_numeric($direct_nid) && !empty($by_technology[$direct_nid])) {
      $form['technology']['#options']['All'] = 'Все технологии';

      foreach ($form['technology']['#options'] as $key => $value) {
        if (is_numeric($key) && ( (!in_array($key, array_keys($by_technology[$direct_nid]))) || (in_array($key, array_keys($by_technology[$direct_nid])) && $by_technology[$direct_nid][$key] == 0) ) ) {
          unset($form['technology']['#options'][$key]);
        }
      }
    }
  }
  
}



/**
 * Implements hook_cron().
 */
function custom_cron() {
  
  variable_set('custom_direction_by_technology', get_direction_by_technology());

}

/**
 *
 */
function get_direction_by_technology() {
  $ret = array();

  $t = db_select('field_data_field_page_type', 't')->fields('t',array('entity_id'))
       ->condition('t.field_page_type_tid', 12)->execute()->fetchCol();
  
  foreach($t as $tnid) {
    $query = db_select('field_data_field_link_material', 'l')
               ->condition('l.field_link_material_nid', $tnid)->condition('l.entity_type', 'node')
               ->condition('l.deleted', 0);
    $query->join('field_data_field_technology', 't', "t.entity_id = l.entity_id AND t.bundle = 'use' AND t.deleted = 0");
    $query->addField('t', 'field_technology_nid', 'technid');
    $query->join('node', 'n', 'n.nid = t.entity_id AND n.status = 1 ');
    $query->addField('l', 'entity_id', 'nid');
    
    $query->addExpression('COUNT(l.entity_id)', 'nids_count');
    $query->groupBy('t.field_technology_nid');
    $result = $query->execute()->fetchAllKeyed();
    $ret[$tnid] = $result;
  }
  return $ret;
}

/**
 * Implements hook_node_view().
 */
function custom_node_view($node, $view_mode, $langcode) {

  //выводим ссылку на все новости
  if($node->type == 'news'){

    // проверяем, находимся ли мы на странице одного из терминов словаря "Тэги новостей"
    ( ($term = menu_get_object('taxonomy_term', 2)) && ($term->vid == 4) ) ? $by_tag = true : $by_tag = false;

    if (!$by_tag) {
      if(isset($node->field_new_image_visible['und'][0]['value'])){
        if($node->field_new_image_visible['und'][0]['value'] == 1){
          unset($node->content['field_news_image']);
        }
      }
      $node->content['all_news'] = array(
          '#markup' => '<a href="/news">Посмотреть <b>все новости</b></a>',
          '#weight' => 3,
          '#prefix' => '<p>',
          '#suffix' => '</p>'
      );
    }
    else { //приводим к виду представления "Новости"
      $pub_date = format_date($node->created, 'custom', 'd F Y', NULL, $langcode);
      $img_weight = (int) $node->content['field_news_image']['#weight'];

      foreach ($node->content as $key => $item) { //смещаем вес элементов, чтобы поставить дату и заголовок после картинки
        if ( is_array($item) && (isset($item['#weight'])) && ($item['#weight'] != $img_weight) ) {
          $node->content[$key]['#weight'] = $item['#weight'] + 2;
        }
        if ($key == 'body') { //обрезаем контент
          $node->content[$key][0]['#markup'] = mb_substr(strip_tags($node->content[$key][0]['#markup']), 0, 250) . '...';
        }
      }
      //добавляем дату, ...
      $node->content['pub_date'] = array(
        '#markup' => '<div class="pub-date">' . $pub_date . '</div>',
        '#weight' => ++$img_weight
      );

      //...заголовок ... //см. node.tpl.php
      $node->content['title'] = array(
        '#markup' => '<a href="/'
                      . drupal_get_path_alias($node->content['links']['node']['#links']['node-readmore']['href'])
                      . '"> '
                      . $node->title
                      . '</a>',
        '#weight' => $img_weight + 2,
        '#prefix' => '<h2 class="node-title">',
        '#suffix' => '</h2>'
      );

      //...и стрелку к "Подробнее"
      if ($node->content['links']['node']['#links']['node-readmore']) {
        $node->content['links']['node']['#links']['node-readmore']['title'] =
          str_ireplace(t('Read more'), t('Read more') . ' →', $node->content['links']['node']['#links']['node-readmore']['title']);
      }
    }
  }

  //выводим фото до и после
  /*
  if($node->type == 'use'){
    $after_before = '';
    $node_wrapper = entity_metadata_wrapper('node', $node);
    $before_items = $node_wrapper->field_col_photo_before->value();
    $after_items = $node_wrapper->field_col_photo_after->value();
    //$before_items = field_get_items('field_collection_item', $node, 'field_col_photo_before');
    //$after_items = field_get_items('field_collection_item', $node, 'field_col_photo_after');

    if(sizeof($before_items)){
      foreach ($before_items as $before_item) {

      }
    }


    dsm($node);
    dsm($before_items);
    dsm($after_items);
    $node->content['all_news'] = array(
        '#markup' => $after_before,
        '#weight' => 3,
        '#prefix' => '<div class="use-after-before">',
        '#suffix' => '</div>'
    );
  }  */

}

function custom_field_collection_item_view($field_collection_item, $view_mode, $langcode){

  //темизируем поля в ноде типа "Применение"
  if($field_collection_item->field_name == 'field_use_before_after'){
    if(isset($field_collection_item->content['field_photo_after'])){
      $field_collection_item->content['field_photo_after']['#prefix'] = '<div class="field-collection-photo-wrapper field-collection-photo-wrapper-after">';
      $field_collection_item->content['field_photo_after']['#suffix'] =
        '<span class="after-desc">'.t("After").'</span></div>';
    }
    if(isset($field_collection_item->content['field_photo_before'])){
      $field_collection_item->content['field_photo_before']['#prefix'] = '<div class="field-collection-photo-wrapper field-collection-photo-wrapper-before">';
      $field_collection_item->content['field_photo_before']['#suffix'] =
        '<span class="before-desc">'.t("Before").'</span></div>';
    }
  }
}

